# === Supabase (database) ===
# Create a free project at https://supabase.com, then copy your project URL and
# service_role key from Project Settings → API.
# When SUPABASE_URL is set, the app uses Supabase; otherwise it falls back to
# local JSON files in .data/ (good for development).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# === Admin credentials ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# === Email (Resend) ===
# Sign up at https://resend.com and get your API key
RESEND_API_KEY=
EMAIL_FROM="Care Conference <noreply@careconference.ng>"
